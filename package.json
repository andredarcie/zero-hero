{
  "name": "zero-the-hero",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:itch": "tsc --noEmit && vite build --base=./",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:world": "tsx scripts/generateWorld.ts",
    "lint": "eslint . --ext .ts",
    "playtest": "node playtest/run.mjs",
    "playtest:text": "node playtest/run.mjs text-legibility",
    "playtest:all": "node playtest/run.mjs all"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
